# ============================================
# OftalmoClaw - Environment Configuration
# By GeekVision
# ============================================

# ---------- REQUIRED ----------

# LLM Provider (pick one or more)
OPENROUTER_API_KEY=sk-or-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# OPENAI_API_KEY=sk-your-key-here

# Application Secret (generate a strong random string)
SECRET_KEY=change-me-to-a-random-secret-key

# ---------- DATABASE ----------

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/oftalmo_claw
# Defaults to SQLite if not set

# ---------- SERVER ----------

PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO
# DEBUG=false

# ---------- MESSAGING GATEWAY ----------

# Telegram
# TELEGRAM_TOKEN=your-bot-token
# TELEGRAM_ALLOWED_USERS=123456789,987654321

# WhatsApp (Cloud API)
# WHATSAPP_TOKEN=your-whatsapp-token
# WHATSAPP_PHONE_ID=your-phone-number-id
# WHATSAPP_VERIFY_TOKEN=your-verify-token

# Discord
# DISCORD_TOKEN=your-discord-bot-token

# Slack
# SLACK_BOT_TOKEN=xoxb-your-token
# SLACK_APP_TOKEN=xapp-your-token

# Email Gateway
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password

# ---------- TOOLS ----------

# Web Search (Parallel API)
# PARALLEL_API_KEY=your-parallel-key

# Web Scraping
# FIRECRAWL_API_KEY=your-firecrawl-key

# Image Generation
# FAL_KEY=your-fal-key

# ---------- STORAGE ----------

# File uploads (S3-compatible)
# S3_ENDPOINT=https://your-s3-endpoint.com
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_BUCKET=oftalmo-claw-uploads

# ---------- MEDICAL ----------

# DICOM Server (PACS integration)
# DICOM_HOST=localhost
# DICOM_PORT=4242
# DICOM_AE_TITLE=OFTALMO_CLAW

# EHR/FHIR Integration
# FHIR_BASE_URL=https://your-fhir-server.com/fhir
# FHIR_CLIENT_ID=your-client-id
# FHIR_CLIENT_SECRET=your-client-secret
